# ============================================
# CONFIGURACION PARA DESPLIEGUE LOCAL (UNIVERSIDAD)
# ============================================
# Copia este archivo como .env y ajusta los valores

# Backend de LLM: "anthropic", "ollama", "vllm", "openai_compatible"
LLM_BACKEND=ollama

# URL del servidor local de modelos
# Ollama default: http://localhost:11434
# vLLM default: http://localhost:8000
LOCAL_MODEL_URL=http://localhost:11434

# Modelo a utilizar
# Ollama: llama3.1:70b, llama3.1:8b, mistral:7b, qwen2.5:72b
# vLLM: meta-llama/Llama-3.1-70B-Instruct
LOCAL_MODEL_NAME=llama3.1:70b

# ============================================
# SOLO SI USAS API DE ANTHROPIC (opcional)
# ============================================
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# CONFIGURACION DEL SERVIDOR WEB
# ============================================
# Puerto para Streamlit (default: 8501)
STREAMLIT_PORT=8501

# Habilitar autenticacion (requiere configuracion adicional)
# AUTH_ENABLED=true
# AUTH_LDAP_SERVER=ldap://universidad.edu
